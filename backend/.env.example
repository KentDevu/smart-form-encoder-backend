# App
APP_NAME=SmartForm Encoder API
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (localhost for local dev, switch to Supabase URL for production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/smartform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=smart-form-encoder
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# AI Vision (for low-confidence OCR enhancement)
# Supports both OpenAI and Groq (OpenAI-compatible API)
# For Groq: use https://api.groq.com/openai/v1 as base URL
# For OpenAI: use https://api.openai.com/v1 as base URL
AI_PROVIDER=groq
AI_API_KEY=your-groq-or-openai-api-key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Legacy OpenAI key (kept for backward compat, prefer AI_* vars above)
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
