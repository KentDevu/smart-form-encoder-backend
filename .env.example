# App
APP_NAME=SmartForm Encoder API
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/smartform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=smartform-uploads
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# AI Vision (Groq/OpenAI compatible)
AI_PROVIDER=groq
AI_API_KEY=
AI_API_KEY_1=
AI_API_KEY_2=
AI_API_KEY_3=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Multi-AI Consensus Validation
AI_CONSENSUS_ENABLED=false
AI_CONSENSUS_MIN_VALIDATORS=3
AI_CONSENSUS_TARGET_AGREEMENT=0.98
AI_CONSENSUS_MAX_ROUNDS=3

# Legacy OpenAI key (fallback)
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# ============================================================
# Memory Optimization (Low-RAM Mode)
# ============================================================
# Set LOW_RAM_MODE=true to enable all memory optimizations
# Use this on systems with <8GB RAM or when memory is limited
LOW_RAM_MODE=false

# Set CACHE_OCR_MODEL=false to reload PaddleOCR per task
# This uses less memory but is slower. Ignored if LOW_RAM_MODE=true
CACHE_OCR_MODEL=true

# Celery worker recycling - restart after N tasks to free memory
CELERY_MAX_TASKS_PER_CHILD=10
