# App
APP_NAME=SmartForm Encoder API
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/smartform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=smartform-uploads
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# AI Vision Provider Configuration
# Options: "openrouter" (recommended—free), "openai" (paid), "groq" (deprecated)
AI_PROVIDER=openrouter

# For OpenRouter (https://openrouter.ai - free tier available)
# Sign up at https://openrouter.ai to get your API key
OPENROUTER_API_KEY=

# OpenRouter endpoint and model selection
# Default: google/gemma-3-27b-it:free (free tier, excellent for handwritten forms)
# Other options: google/gemma-3-12b-it:free (smaller), openai/gpt-4-vision (paid)
AI_BASE_URL=https://openrouter.ai/api/v1
AI_VISION_MODEL=google/gemma-3-27b-it:free

# Legacy keys (for backwards compatibility, only used if AI_PROVIDER not openrouter)
# OPENAI_API_KEY= (for AI_PROVIDER=openai)
# AI_API_KEY= (for AI_PROVIDER=groq, deprecated)
AI_API_KEY=
AI_API_KEY_1=
AI_API_KEY_2=
AI_API_KEY_3=
OPENAI_API_KEY=

# Multi-AI Consensus Validation
AI_CONSENSUS_ENABLED=false
AI_CONSENSUS_MIN_VALIDATORS=3
AI_CONSENSUS_TARGET_AGREEMENT=0.98
AI_CONSENSUS_MAX_ROUNDS=3

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# ============================================================
# Memory Optimization (Low-RAM Mode)
# ============================================================
# Set LOW_RAM_MODE=true to enable all memory optimizations
# Use this on systems with <8GB RAM or when memory is limited
LOW_RAM_MODE=false

# Set CACHE_OCR_MODEL=false to reload PaddleOCR per task
# This uses less memory but is slower. Ignored if LOW_RAM_MODE=true
CACHE_OCR_MODEL=true

# Celery worker recycling - restart after N tasks to free memory
CELERY_MAX_TASKS_PER_CHILD=10
